# =========================================================================
# Ford FIAP Challenge — Environment Variables
# =========================================================================
# Para rodar local: copie este arquivo para .env.local e preencha.
# .env.local NUNCA vai pro git (está no .gitignore).
# Em CI, use GitHub Actions Secrets — nunca cole valores aqui.
# =========================================================================

# ----- Supabase -----
# URL semi-pública (pode aparecer em logs do app)
SUPABASE_URL=https://<project-ref>.supabase.co

# Chave pública (anon) — pode ser usada no mobile/frontend porque RLS protege.
SUPABASE_ANON_KEY=<anon-key>

# Chave de service role — APENAS NO BACKEND, e só em rotas admin (apps/api/src/admin/**).
# Nunca colocar no mobile, nunca logar, nunca aparecer em commit.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Segredo para validar JWTs emitidos pelo Supabase. Backend only.
SUPABASE_JWT_SECRET=<jwt-secret>

# ----- Anthropic Claude (insights de IA) -----
# Usar Haiku para XAI per-client (barato), Sonnet para análises de carteira.
ANTHROPIC_API_KEY=<sk-ant-...>
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_MODEL_SMART=claude-sonnet-4-6

# ----- API Gateway (Node + Fastify) -----
API_PORT=3333
API_HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000,exp://192.168.1.0:8081
LOG_LEVEL=info
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

# URL do serviço de ML (Python FastAPI)
ML_SERVICE_URL=http://localhost:8001
ML_SERVICE_TOKEN=<shared-secret-entre-api-e-ml>

# ----- ML Service (Python + FastAPI) -----
ML_PORT=8001
MODELS_DIR=./services/ml/models
SYNTHETIC_DATA_DIR=./services/ml/data

# ----- Mobile (Expo) — apenas chaves PÚBLICAS aqui -----
# Estas duas vão em apps/mobile/.env.local com prefixo EXPO_PUBLIC_*
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
EXPO_PUBLIC_API_URL=http://localhost:3333
